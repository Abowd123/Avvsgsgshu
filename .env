# AI Code Bot — environment configuration
# انسخ القيم الحقيقية هنا محلياً؛ لا تشارك هذا الملف أو تضعه في أي مستودع عام.

TELEGRAM_BOT_TOKEN=123456:ABC...        # مطلوب (BOT_TOKEN لا يزال مقبولاً كبديل)

# --- مفاتيح مزودات الذكاء الاصطناعي: لم تعد تحتاج تعديل هذا الملف ---
# بعد تشغيل البوت، افتح تيليجرام وأرسل /keys (أو اضغط زر "🔑 مفاتيح API" في القائمة
# الرئيسية — يظهر فقط لمن هو ضمن ADMIN_IDS أدناه) لإضافة أو تغيير أو حذف مفتاح أي
# مزود مباشرة من داخل البوت، بدون لمس هذا الملف وبدون إعادة تشغيل العملية.
# المفاتيح المُدخلة عبر /keys تُخزَّن في API_KEYS_FILE (افتراضياً: data/api_keys.json)
# ولها الأولوية دائماً على قيمة {PREFIX}_API_KEY أدناه لو كانت موجودة في كلا المكانين.
# يمكنك ترك كل قيم *_API_KEY أدناه فارغة والاعتماد كلياً على /keys إذا أردت.
API_KEYS_FILE=data/api_keys.json

# --- DeepSeek: المزود الأساسي (اختياري إذا توفّر مزود آخر) ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_THINKING=false                 # true فقط لموديلات reasoning
DEEPSEEK_REASONING_EFFORT=high          # high | max
DEEPSEEK_ENABLED=true

# --- Groq: مزود احتياطي (اختياري) ---
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=32768
GROQ_TEMPERATURE=0.2
GROQ_ENABLED=true

# --- OpenRouter: مزود احتياطي (اختياري) ---
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_THINKING=false               # true فقط لموديلات reasoning
OPENROUTER_REASONING_EFFORT=high        # high | max
OPENROUTER_ENABLED=true

# --- Cerebras: استدلال فائق السرعة (اختياري) ---
CEREBRAS_API_KEY=
CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_MAX_TOKENS=8192
CEREBRAS_TEMPERATURE=0.2
CEREBRAS_ENABLED=true

# --- Gemini (Google): عبر الواجهة المتوافقة مع OpenAI (اختياري) ---
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GEMINI_MODEL=gemini-2.5-flash            # أو gemini-3.5-flash إن توفّر لحسابك
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2
GEMINI_ENABLED=true

# --- Mistral (اختياري) ---
MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_MODEL=mistral-large-latest
MISTRAL_MAX_TOKENS=8192
MISTRAL_TEMPERATURE=0.2
MISTRAL_ENABLED=true

# --- Fireworks AI (اختياري) ---
FIREWORKS_API_KEY=
FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
FIREWORKS_MAX_TOKENS=8192
FIREWORKS_TEMPERATURE=0.2
FIREWORKS_ENABLED=true

# --- Together AI (اختياري) ---
TOGETHER_API_KEY=
TOGETHER_API_URL=https://api.together.xyz/v1/chat/completions
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_MAX_TOKENS=8192
TOGETHER_TEMPERATURE=0.2
TOGETHER_ENABLED=true

# --- DeepInfra (اختياري) ---
DEEPINFRA_API_KEY=
DEEPINFRA_API_URL=https://api.deepinfra.com/v1/openai/chat/completions
DEEPINFRA_MODEL=deepseek-ai/DeepSeek-V3
DEEPINFRA_MAX_TOKENS=8192
DEEPINFRA_TEMPERATURE=0.2
DEEPINFRA_ENABLED=true

# --- SiliconFlow (اختياري) ---
SILICONFLOW_API_KEY=
SILICONFLOW_API_URL=https://api.siliconflow.com/v1/chat/completions
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_MAX_TOKENS=8192
SILICONFLOW_TEMPERATURE=0.2
SILICONFLOW_ENABLED=true

# --- Moonshot AI (Kimi) (اختياري) ---
MOONSHOT_API_KEY=
MOONSHOT_API_URL=https://api.moonshot.ai/v1/chat/completions
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_MAX_TOKENS=8192
MOONSHOT_TEMPERATURE=0.2
MOONSHOT_ENABLED=true

# --- Z.AI (GLM) (اختياري) ---
ZAI_API_KEY=
ZAI_API_URL=https://api.z.ai/api/paas/v4/chat/completions
ZAI_MODEL=glm-5.2
ZAI_MAX_TOKENS=8192
ZAI_TEMPERATURE=0.2
ZAI_THINKING=false                      # true فقط لموديلات reasoning
ZAI_REASONING_EFFORT=high               # high | max
ZAI_ENABLED=true

# --- Qwen عبر DashScope الدولية (اختياري) ---
QWEN_API_KEY=
QWEN_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus
QWEN_MAX_TOKENS=8192
QWEN_TEMPERATURE=0.2
QWEN_ENABLED=true

# --- xAI (Grok) (اختياري) ---
XAI_API_KEY=
XAI_API_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL=grok-4
XAI_MAX_TOKENS=8192
XAI_TEMPERATURE=0.2
XAI_ENABLED=true

# --- Perplexity (اختياري؛ نماذج sonar تُرفق نتائج بحث مع الرد) ---
PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
PERPLEXITY_MODEL=sonar
PERPLEXITY_MAX_TOKENS=8192
PERPLEXITY_TEMPERATURE=0.2
PERPLEXITY_ENABLED=true

# --- SambaNova (اختياري) ---
SAMBANOVA_API_KEY=
SAMBANOVA_API_URL=https://api.sambanova.ai/v1/chat/completions
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_MAX_TOKENS=8192
SAMBANOVA_TEMPERATURE=0.2
SAMBANOVA_ENABLED=true

# --- Lambda (Lambda Labs Inference) (اختياري) ---
LAMBDA_API_KEY=
LAMBDA_API_URL=https://api.lambda.ai/v1/chat/completions
LAMBDA_MODEL=llama-3.3-70b-instruct-fp8
LAMBDA_MAX_TOKENS=8192
LAMBDA_TEMPERATURE=0.2
LAMBDA_ENABLED=true

# --- Hyperbolic (اختياري) ---
HYPERBOLIC_API_KEY=
HYPERBOLIC_API_URL=https://api.hyperbolic.xyz/v1/chat/completions
HYPERBOLIC_MODEL=meta-llama/Llama-3.3-70B-Instruct
HYPERBOLIC_MAX_TOKENS=8192
HYPERBOLIC_TEMPERATURE=0.2
HYPERBOLIC_ENABLED=true

# --- GitHub Models (اختياري) ---
# تنبيه: أعلنت GitHub التقاعد الكامل لهذه الخدمة بتاريخ 30 يوليو 2026.
# لا تعتمد عليها كمزود وحيد أو أساسي — استخدمها فقط كخيار احتياطي مؤقت.
# المفتاح هنا هو GitHub Personal Access Token بصلاحية "models: read".
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_API_URL=https://models.github.ai/inference/chat/completions
GITHUB_MODELS_MODEL=openai/gpt-4.1
GITHUB_MODELS_MAX_TOKENS=8192
GITHUB_MODELS_TEMPERATURE=0.2
GITHUB_MODELS_ENABLED=true

# --- Upstage (Solar) (اختياري) ---
UPSTAGE_API_KEY=
UPSTAGE_API_URL=https://api.upstage.ai/v1/chat/completions
UPSTAGE_MODEL=solar-pro2                # أو solar-pro3 إن توفّر لحسابك
UPSTAGE_MAX_TOKENS=8192
UPSTAGE_TEMPERATURE=0.2
UPSTAGE_ENABLED=true

# --- توجيه/صحة المزودات ---
# ملاحظة: ترتيب المزودات في priority هو نفس ترتيبهم أعلاه في هذا الملف
# (DeepSeek → Groq → OpenRouter → Cerebras → ... → Upstage). فعّل فقط من تريد
# استخدامه فعلياً؛ أي مزود بلا مفتاح API يُتجاهل تلقائياً بلا أي خطأ.
AI_ROUTING=priority                     # priority (بنفس ترتيب المزودات أدناه) | fastest
AI_HEALTH_INTERVAL=300                  # ثواني بين فحوصات الصحة (0 = تعطيل)
AI_PROBE_TIMEOUT=15
AI_TEMPERATURE=0.2                      # افتراضي لكل المزودات

# --- قاطع الدارة (circuit breaker) ---
CIRCUIT_BREAK_THRESHOLD=3               # عدد الأخطاء المتتالية قبل الإيقاف المؤقت
CIRCUIT_BREAK_COOLDOWN=300              # ثواني بقاء المزود متوقفاً

# --- كاش النتائج ---
CACHE_TTL_SECONDS=3600                  # مدة صلاحية النتيجة المخزنة
CACHE_MAX_ENTRIES=500                   # الحد الأقصى لعناصر الكاش (LRU)

# --- الشبكة وإعادة المحاولة ---
REQUEST_TIMEOUT=600
MAX_RETRIES=3
RETRY_DELAY=2.0
VALIDATION_RETRIES=1

# --- الحدود على الملفات/المشاريع ---
MAX_FILE_SIZE=200000                    # بايت، لكل ملف مصدري (وينطبق أيضاً على ملف GitHub المفرد)
MAX_ARCHIVE_SIZE=15000000               # بايت، ملف zip المرفوع (وكذلك zip المُجلَب من GitHub/gist)
MAX_ARCHIVE_ENTRIES=2000
MAX_EXTRACTED_SIZE=25000000             # بايت بعد فك الضغط
MAX_PROJECT_FILES=20                    # عدد الملفات المرسلة للذكاء الاصطناعي لكل مشروع
PROJECT_PARALLELISM=3
MAX_CONTEXT_FILES=6                     # ملفات السياق المرتبطة (للقراءة فقط)
MAX_CONTEXT_CHARS=40000
MAX_CHUNKS=24

# --- قائمة الانتظار والمستخدمون ---
MAX_CONCURRENT_JOBS=4                   # عدد العمال (workers) في الطابور
MAX_HISTORY=10                          # عدد العمليات المحفوظة لكل مستخدم
USER_COOLDOWN=1.0                       # ثواني بين رسائل نفس المستخدم
ALLOWED_USER_IDS=                       # فارغ = مفتوح للجميع (افصل عدة IDs بفاصلة)
ADMIN_IDS=                              # مطلوب لتفعيل /ai_status و /cache_status (افصل بفاصلة)

# --- السجلات (logs) ---
LOG_DIR=logs
LOG_TO_FILE=true
LOG_LEVEL=INFO

# ملاحظة حول ميزة GitHub:
# - جلب المحتوى من روابط GitHub (ملف/repo/gist) لا يحتاج أي متغير بيئة إضافي هنا
#   (يعمل بدون توكن للمستودعات/الـ gists العامة، عبر aiohttp مباشرة).
# - الـ Personal Access Token (PAT) الخاص بزر "رفع لـ GitHub" لا يُكتب أبداً في هذا
#   الملف؛ يُرسله المستخدم داخل المحادثة عند الحاجة فقط، ويُستخدم لحظياً ثم يُحذف
#   فوراً من الذاكرة (لا يُخزَّن ولا يُسجَّل في أي مكان).
